    "react-dom": "19.2.5",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "1.59.1",
    "@stylistic/eslint-plugin": "5.10.0",
    "@types/node": "20.19.39",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitest/coverage-v8": "4.1.4",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.3",
    "typescript": "5.9.3",
    "vitest": "4.1.4"
  },
  "packageManager": "pnpm@10.30.2"
